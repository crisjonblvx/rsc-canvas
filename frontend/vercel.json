{
  "version": 2,
  "name": "readysetclass",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard-v2.html"
    },
    {
      "src": "/v2",
      "dest": "/dashboard-v2.html"
    },
    {
      "src": "/dashboard-v2.html",
      "dest": "/dashboard-v2.html"
    },
    {
      "src": "/landing",
      "dest": "/landing-page.html"
    },
    {
      "src": "/landing-page.html",
      "dest": "/landing-page.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/dashboard.html"
    },
    {
      "src": "/grading.html",
      "dest": "/grading.html"
    },
    {
      "src": "/grading",
      "dest": "/grading.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/locales/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  }
}
