{
  "version": 2,
  "name": "readysetclass",
  "github": {
    "silent": false
  },
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "frontend",
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard-v2.html"
    },
    {
      "src": "/v2",
      "dest": "/dashboard-v2.html"
    },
    {
      "src": "/grading.html",
      "dest": "/grading.html"
    },
    {
      "src": "/grading",
      "dest": "/grading.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
